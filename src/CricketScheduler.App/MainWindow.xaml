<Window x:Class="CricketScheduler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cricket Tournament Scheduler"
        Height="720"
        Width="1200">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
            <TextBlock Text="Leagues" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
            <ComboBox ItemsSource="{Binding LeagueNames}" SelectedItem="{Binding SelectedLeagueName}" Margin="0,0,0,8"/>
            <Button Content="Create League" Command="{Binding CreateLeagueCommand}" Margin="0,0,0,6"/>
            <Button Content="Open League" Command="{Binding OpenLeagueCommand}" Margin="0,0,0,6"/>
            <Button Content="Delete League" Command="{Binding DeleteLeagueCommand}" Margin="0,0,0,12"/>

            <Button Content="Generate Schedule" Command="{Binding GenerateScheduleCommand}" Margin="0,0,0,6"/>
            <Button Content="Export CSV" Command="{Binding ExportScheduleCommand}" />
        </StackPanel>

        <Border Grid.Column="2" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10">
            <DataGrid ItemsSource="{Binding ScheduledMatches}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Sequence}" Width="50"/>
                    <DataGridTextColumn Header="Division" Binding="{Binding DivisionName}" Width="120"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding TimeRange}" Width="120"/>
                    <DataGridTextColumn Header="Team One" Binding="{Binding TeamOne}" Width="*"/>
                    <DataGridTextColumn Header="Team Two" Binding="{Binding TeamTwo}" Width="*"/>
                    <DataGridTextColumn Header="Ground" Binding="{Binding GroundName}" Width="140"/>
                    <DataGridTextColumn Header="Umpire 1" Binding="{Binding UmpireOne}" Width="120"/>
                    <DataGridTextColumn Header="Umpire 2" Binding="{Binding UmpireTwo}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>

<Window x:Class="CricketScheduler.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CricketScheduler.App.Views"
        Title="Cricket Tournament Scheduler"
        Height="840"
        Width="1300">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- League Toolbar -->
        <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="6"
                Padding="10,8" Background="#F5F5F5">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Cricket Scheduler"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,18,0"/>

                <TextBlock DockPanel.Dock="Left" Text="League:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox DockPanel.Dock="Left" Width="230"
                          ItemsSource="{Binding LeagueNames}"
                          SelectedItem="{Binding SelectedLeagueName}"
                          Margin="0,0,8,0"/>
                <Button DockPanel.Dock="Left" Content="Open"
                        Command="{Binding OpenLeagueCommand}" Padding="10,5" Margin="0,0,6,0"/>
                <Button DockPanel.Dock="Left" Content="New League"
                        Command="{Binding CreateLeagueCommand}" Padding="10,5" Margin="0,0,6,0"/>
                <Button DockPanel.Dock="Left" Content="Delete"
                        Command="{Binding DeleteLeagueCommand}" Padding="10,5"/>

                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" Foreground="#555" FontStyle="Italic"/>
            </DockPanel>
        </Border>

        <!-- Main Tabs — each tab hosts its dedicated UserControl View -->
        <TabControl Grid.Row="2">

            <TabItem Header="Tournament">
                <views:TournamentView/>
            </TabItem>

            <TabItem Header="Divisions">
                <views:DivisionView/>
            </TabItem>

            <TabItem Header="Requests">
                <views:SchedulingRequestView/>
            </TabItem>

            <TabItem Header="Scheduler">
                <views:SchedulerView/>
            </TabItem>

        </TabControl>
    </Grid>
</Window>

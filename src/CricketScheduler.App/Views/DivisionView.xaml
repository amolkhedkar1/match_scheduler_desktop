<UserControl x:Class="CricketScheduler.App.Views.DivisionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CricketScheduler.App"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="FI" TargetType="TextBox">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Background" Value="#FAFAFA"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ══ COL 0: Division list + add form ══════════════════════════════ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header + search -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Divisions" Style="{StaticResource Hdr}"/>
                <TextBox Text="{Binding DivisionSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4" Margin="0,0,0,6" ToolTip="Search divisions…"/>
            </StackPanel>

            <!-- Division list — shows name + mode summary -->
            <ListBox Grid.Row="1" ItemsSource="{Binding FilteredDivisions}"
                     SelectedItem="{Binding SelectedDivision}" MinHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ModeSummary}" FontSize="11" Foreground="#777"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Add new division form -->
            <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Add New Division" Style="{StaticResource Hdr}"/>

                    <TextBlock Text="Division Name" Style="{StaticResource FL}"/>
                    <TextBox Text="{Binding NewDivisionName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FI}"/>

                    <TextBlock Text="Scheduling Mode" Style="{StaticResource FL}"/>
                    <RadioButton Content="Round Robin (all unique pairs)"
                                 IsChecked="{Binding NewDivisionIsRoundRobin}"
                                 GroupName="newMode" Margin="0,2,0,2"/>
                    <RadioButton Content="Fixed matches per team"
                                 IsChecked="{Binding NewDivisionIsRoundRobin, Converter={x:Static local:InverseBoolConverter.Instance}, Mode=OneWay}"
                                 GroupName="newMode" Margin="0,2,0,4"/>

                    <DockPanel LastChildFill="False">
                        <TextBlock Text="Matches per team:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding NewDivisionMatchesPerTeam, UpdateSourceTrigger=PropertyChanged}"
                                 Width="55" Style="{StaticResource FI}"
                                 ToolTip="How many opponents each team plays (fixed mode only)"/>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="➕ Add" Command="{Binding AddDivisionCommand}"
                                Padding="10,5" Margin="0,0,6,0"/>
                        <Button Content="🗑 Remove" Command="{Binding RemoveDivisionCommand}"
                                Padding="10,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save + Import + Append -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="💾 Save" Command="{Binding SaveDivisionsCommand}"
                        FontWeight="SemiBold" Padding="12,7" Margin="0,0,6,0"
                        Background="#4CAF50" Foreground="White"/>
                <Button Content="📂 Import CSV" Command="{Binding ImportDivisionsCommand}"
                        Padding="10,7" Margin="0,0,6,0"/>
                <Button Content="📎 Append CSV" Command="{Binding AppendDivisionsCommand}"
                        Padding="10,7" ToolTip="Append teams/divisions from an additional CSV file"/>
            </StackPanel>
        </Grid>

        <!-- ══ COL 2: Teams + Pairings for selected division ══════════════════ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Style="{StaticResource Hdr}">
                <Run Text="Teams in: "/>
                <Run Text="{Binding SelectedDivisionName, Mode=OneWay}" FontStyle="Italic"/>
            </TextBlock>

            <!-- Team toolbar -->
            <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,0,0,6">
                <Button DockPanel.Dock="Left" Content="🗑 Delete Selected"
                        Command="{Binding DeleteSelectedDivisionTeamsCommand}"
                        CommandParameter="{Binding ElementName=TeamGrid}"
                        Padding="10,4" Margin="0,0,6,0"/>
                <Button DockPanel.Dock="Left" Content="📂 Import Teams CSV"
                        Command="{Binding ImportDivisionsCommand}" Padding="10,4" Margin="0,0,6,0"/>
                <TextBox DockPanel.Dock="Left" Width="130"
                         Text="{Binding NewTeamName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3" ToolTip="New team name" Margin="0,0,4,0"/>
                <Button DockPanel.Dock="Left" Content="➕ Add" Command="{Binding AddTeamCommand}"
                        Padding="8,4"/>
            </DockPanel>

            <!-- Multi-select team grid -->
            <DataGrid Grid.Row="2" x:Name="TeamGrid"
                      ItemsSource="{Binding TeamsInSelectedDivision}"
                      SelectedItem="{Binding SelectedTeam}"
                      SelectionMode="Extended"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                      CanUserResizeColumns="True" CanUserSortColumns="True">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="ToolTip" Value="Click to sort · Shift+click for multi-column sort"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Team Name" Binding="{Binding Name}"         Width="*"   SortMemberPath="Name"/>
                    <DataGridTextColumn Header="Division"  Binding="{Binding DivisionName}" Width="160" SortMemberPath="DivisionName"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Pairings section — visible only for Fixed-mode divisions -->
            <Border Grid.Row="3" Style="{StaticResource Panel}" Margin="0,8,0,0"
                    Visibility="{Binding SelectedDivisionIsFixed, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,6">
                        <TextBlock DockPanel.Dock="Left" Text="Match Pairings (Fixed Mode)"
                                   Style="{StaticResource Hdr}" Margin="0"/>
                        <Button DockPanel.Dock="Right" Content="🔄 Generate Pairings"
                                Command="{Binding GeneratePairingsCommand}"
                                Padding="10,4" Background="#1976D2" Foreground="White"/>
                    </DockPanel>
                    <TextBlock FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,0,0,6">
                        Teams sorted alphabetically. Team 1 skips Team N, Team 2 skips Team N-1, etc., so each plays exactly MatchesPerTeam opponents.
                    </TextBlock>
                    <DataGrid ItemsSource="{Binding SelectedDivisionPairings}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              MaxHeight="180" CanUserResizeColumns="True" CanUserSortColumns="True">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="6,4"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="ToolTip" Value="Click to sort · Shift+click for multi-column sort"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"      Binding="{Binding Index}" Width="35"  SortMemberPath="Index"/>
                            <DataGridTextColumn Header="Team A" Binding="{Binding TeamA}" Width="*"   SortMemberPath="TeamA"/>
                            <DataGridTextColumn Header="Team B" Binding="{Binding TeamB}" Width="*"   SortMemberPath="TeamB"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- spacer row -->
            <Border Grid.Row="4"/>
        </Grid>

        <!-- ══ COL 4: Edit scheduling mode for selected division ════════════ -->
        <Border Grid.Column="4" Style="{StaticResource Panel}">
            <StackPanel>
                <TextBlock Style="{StaticResource Hdr}">
                    <Run Text="Scheduling Mode"/>
                </TextBlock>
                <TextBlock FontSize="11" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,10">
                    Choose how matches are generated for the selected division.
                    Changes take effect on the next Generate or Reschedule.
                </TextBlock>

                <!-- Current selection indicator -->
                <Border BorderBrush="#4CAF50" BorderThickness="1" CornerRadius="4"
                        Padding="8,6" Margin="0,0,0,12" Background="#F1F8E9">
                    <StackPanel>
                        <TextBlock Text="Selected Division:" FontSize="11" Foreground="#555"/>
                        <TextBlock Text="{Binding SelectedDivisionName, Mode=OneWay}"
                                   FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="{Binding SelectedDivision.ModeSummary, Mode=OneWay}"
                                   FontSize="11" Foreground="#388E3C" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <Separator Margin="0,0,0,10"/>

                <!-- Round Robin option -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4"
                        Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <RadioButton Content="Round Robin"
                                     IsChecked="{Binding EditDivisionIsRoundRobin}"
                                     GroupName="editMode"
                                     FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="18,4,0,0">
                            Every team plays every other team exactly once.
                            Total matches = N × (N−1) / 2.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Fixed matches option -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="4"
                        Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <RadioButton Content="Fixed matches per team"
                                     IsChecked="{Binding EditDivisionIsRoundRobin,
                                         Converter={x:Static local:InverseBoolConverter.Instance}}"
                                     GroupName="editMode"
                                     FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="18,4,0,8">
                            Each team plays a set number of opponents.
                            Pairs are balanced across all teams.
                        </TextBlock>
                        <DockPanel LastChildFill="False" Margin="18,0,0,0">
                            <TextBlock Text="Matches per team:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding EditDivisionMatchesPerTeam, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60" Padding="4"
                                     ToolTip="e.g. 4 means each team plays 4 different opponents"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Button Content="✔ Apply to Division" Command="{Binding UpdateDivisionModeCommand}"
                        FontWeight="SemiBold" Padding="12,8" HorizontalAlignment="Stretch"
                        Background="#1976D2" Foreground="White"/>

                <Separator Margin="0,14"/>

                <!-- Quick reference -->
                <TextBlock Text="Match Count Reference" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock FontSize="11" Foreground="#555" TextWrapping="Wrap">
                    <Run FontWeight="SemiBold">Round Robin examples:</Run><LineBreak/>
                    4 teams → 6 matches<LineBreak/>
                    6 teams → 15 matches<LineBreak/>
                    8 teams → 28 matches<LineBreak/>
                    <LineBreak/>
                    <Run FontWeight="SemiBold">Fixed mode example:</Run><LineBreak/>
                    8 teams, 4 matches/team → 16 matches total
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

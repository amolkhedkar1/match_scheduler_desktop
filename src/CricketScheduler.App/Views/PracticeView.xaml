<UserControl x:Class="CricketScheduler.App.Views.PracticeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="ColHdr" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style x:Key="Grid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ColHdr}"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="10">

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Pill}">
            <WrapPanel>
                <Button Content="🏏 Generate Practice Schedule"
                        Command="{Binding GeneratePracticeScheduleCommand}"
                        FontWeight="SemiBold" Style="{StaticResource Btn}"
                        Background="#1565C0" Foreground="White"
                        ToolTip="Generate weekday practice slots for all teams with upcoming weekend matches"/>
                <Separator Width="1" Height="22" Background="#CCC" Margin="4,0"/>
                <Button Content="📤 Export CSV"
                        Command="{Binding ExportPracticeScheduleCommand}"
                        Style="{StaticResource Btn}"
                        ToolTip="Export practice schedule to a CSV file"/>
            </WrapPanel>
        </Border>

        <!-- Algorithm description -->
        <Border DockPanel.Dock="Top" Background="#EEF4FB" BorderBrush="#B0C4DE"
                BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,0,0,6">
            <TextBlock TextWrapping="Wrap" Foreground="#1A3A5C" FontSize="11">
                <Run FontWeight="SemiBold">Algorithm: </Run>
                <Run>For each weekend with scheduled matches, teams practice at their match ground on a weekday (Mon–Fri) of that week.
Up to 3 teams share one slot per day per ground. No two same-division teams share a slot. Days are distributed evenly across teams.</Run>
            </TextBlock>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#F5F5F5" BorderBrush="#DDD"
                BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="0,6,0,0">
            <TextBlock Text="{Binding PracticeStatusMessage}" Foreground="#555" FontStyle="Italic" FontSize="11"/>
        </Border>

        <!-- Practice slots grid -->
        <DataGrid Style="{StaticResource Grid}"
                  ItemsSource="{Binding PracticeSlots}"
                  SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Date"      Binding="{Binding DateDisplay}" Width="100"/>
                <DataGridTextColumn Header="Day"       Binding="{Binding DayOfWeek}"   Width="90"/>
                <DataGridTextColumn Header="Ground"    Binding="{Binding Ground}"      Width="160"/>
                <DataGridTextColumn Header="Team 1"    Binding="{Binding TeamOne}"     Width="*"/>
                <DataGridTextColumn Header="Team 2"    Binding="{Binding TeamTwo}"     Width="*"/>
                <DataGridTextColumn Header="Team 3"    Binding="{Binding TeamThree}"   Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>

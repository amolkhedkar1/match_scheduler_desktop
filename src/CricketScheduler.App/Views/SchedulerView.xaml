<UserControl x:Class="CricketScheduler.App.Views.SchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CricketScheduler.App"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style x:Key="ColHdr" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Click to sort · Shift+click for multi-column sort"/>
        </Style>
        <Style x:Key="Grid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ColHdr}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- shared toolbar -->
            <RowDefinition Height="*"/>     <!-- tab content -->
        </Grid.RowDefinitions>

        <!-- ══ SHARED TOOLBAR ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Pill}">
            <WrapPanel>
                <Button Content="⚡ Generate"        Command="{Binding GenerateScheduleCommand}"
                        FontWeight="SemiBold" Style="{StaticResource Btn}"/>
                <Button Content="🔄 Reschedule"      Command="{Binding RescheduleCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"
                        Style="{StaticResource Btn}"
                        ToolTip="Re-run keeping Fixed matches; respects Forbidden Slots&#x0a;Select &gt;1 rows to reschedule only those non-fixed matches"/>
                <Separator Width="1" Height="22" Background="#CCC" Margin="4,0"/>
                <Button Content="💾 Save Schedule"    Style="{StaticResource Btn}"
                        Command="{Binding SaveScheduleCommand}"
                        Background="#2E7D32" Foreground="White" FontWeight="SemiBold"
                        ToolTip="Save current scheduled and unscheduled matches to persistent storage"/>
                <Separator Width="1" Height="22" Background="#CCC" Margin="4,0"/>
                <Button Content="📤 Export All"      Command="{Binding ExportScheduleCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}" Style="{StaticResource Btn}"
                        ToolTip="Export all scheduled matches in the current grid sort order"/>
                <Button Content="📤 Export Filtered" Command="{Binding ExportFilteredScheduleCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}" Style="{StaticResource Btn}"
                        ToolTip="Export only the currently visible (filtered) matches in grid sort order"/>
                <Button Content="📤 Unscheduled"     Command="{Binding ExportUnscheduledCommand}"    Style="{StaticResource Btn}"/>
                <Button Content="📂 Import"          Command="{Binding ImportMatchesCommand}"        Style="{StaticResource Btn}"/>
                <Separator Width="1" Height="22" Background="#CCC" Margin="4,0"/>
                <Button Content="📌 Toggle Fixed"    Style="{StaticResource Btn}"
                        Command="{Binding ToggleFixedSelectedCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"
                        ToolTip="Mark/unmark selected scheduled matches as fixed"/>
                <Button Content="📋 Copy"            Style="{StaticResource Btn}"
                        Command="{Binding CopySelectedMatchesCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"/>
                <Button Content="📋 Paste"           Style="{StaticResource Btn}"  Command="{Binding PasteMatchesCommand}"/>
                <Button Content="📤 Unschedule"      Style="{StaticResource Btn}"
                        Command="{Binding UnscheduleSelectedMatchesCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"
                        Background="#E65100" Foreground="White"
                        ToolTip="Move selected scheduled matches back to Unscheduled grid"/>
                <Button Content="🗑 Delete"          Style="{StaticResource Btn}"
                        Command="{Binding DeleteSelectedMatchesCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"/>
                <Separator Width="1" Height="22" Background="#CCC" Margin="4,0"/>
                <!-- Opens the solitaire Move Analyzer popup -->
                <Button Content="↔ Move Analyzer"   Style="{StaticResource Btn}"
                        Command="{Binding OpenMoveAnalyzerCommand}"
                        CommandParameter="{Binding SelectedMatch}"
                        Background="#1565C0" Foreground="White" FontWeight="SemiBold"
                        ToolTip="Open Move Analyzer popup for the selected scheduled match"/>
                <Separator Width="1" Height="22" Background="#CCC" Margin="4,0"/>
                <Button Content="🧑‍⚖️ Reschedule Umpiring" Style="{StaticResource Btn}"
                        Command="{Binding RescheduleUmpiringCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"
                        Background="#4A148C" Foreground="White" FontWeight="SemiBold"
                        ToolTip="Re-assign umpires for all non-fixed matches&#x0a;Priority: adjacent slot → same day → free this week → least load&#x0a;Rules: never same division, never umpiring own match&#x0a;Select &gt;1 rows to re-assign umpires only for those non-fixed matches"/>
                <Button Content="🏟 Reschedule Ground &amp; Umpiring" Style="{StaticResource Btn}"
                        Command="{Binding RescheduleGroundAndUmpiringCommand}"
                        CommandParameter="{Binding ElementName=MatchGrid}"
                        Background="#006064" Foreground="White" FontWeight="SemiBold"
                        ToolTip="Balance ground assignments across all non-fixed matches, then re-assign umpires.&#x0a;Fixed matches are completely untouched.&#x0a;Hard constraint: no two matches share the same ground + date + time slot.&#x0a;Select &gt;1 rows to rebalance only those non-fixed matches"/>
                <TextBlock Text="{Binding ScheduleStats}" VerticalAlignment="Center"
                           Foreground="#555" FontStyle="Italic" Margin="8,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- ══ TAB CONTROL ══════════════════════════════════════════════════ -->
        <TabControl Grid.Row="1">

            <!-- ═══ TAB 1: SCHEDULED ════════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅 Scheduled"/>
                        <Border Background="#1565C0" CornerRadius="8" Padding="5,1" Margin="6,0,0,0">
                            <TextBlock Text="{Binding FilteredScheduledMatches.Count, Mode=OneWay}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- filter bar -->
                        <RowDefinition Height="Auto"/>  <!-- forbidden slots -->
                        <RowDefinition Height="*"/>     <!-- match grid -->
                    </Grid.RowDefinitions>

                    <!-- Filter bar -->
                    <Border Grid.Row="0" Style="{StaticResource Pill}">
                        <WrapPanel>
                            <TextBlock Text="Division:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                            <ComboBox Width="130" ItemsSource="{Binding FilterDivisions}"
                                      SelectedItem="{Binding FilterDivision}" Margin="0,0,10,0"/>
                            <TextBlock Text="Team:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                            <ComboBox Width="160" ItemsSource="{Binding FilterTeams}"
                                      SelectedItem="{Binding FilterTeam}" Margin="0,0,10,0"/>
                            <TextBlock Text="Ground:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                            <ComboBox Width="130" ItemsSource="{Binding FilterGrounds}"
                                      SelectedItem="{Binding FilterGround}" Margin="0,0,10,0"/>
                            <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding ScheduleSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Width="170" Padding="4,3" Margin="0,0,8,0"
                                     ToolTip="Search team, ground, division or date"/>
                            <Button Content="✕ Clear" Command="{Binding ClearFiltersCommand}" Padding="8,4"/>
                            <TextBlock Text="  ℹ Shift+click column for multi-sort"
                                       FontSize="11" Foreground="#888" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </Border>

                    <!-- Forbidden slots (collapsed by default) -->
                    <Border Grid.Row="1" Style="{StaticResource Pill}">
                        <Expander Header="🚫  Forbidden Slots — excluded from all scheduling" IsExpanded="False">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Date" FontSize="11" Foreground="#555"/>
                                        <DatePicker SelectedDate="{Binding NewForbiddenDate}" Width="130"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Ground" FontSize="11" Foreground="#555"/>
                                        <ComboBox Width="140" ItemsSource="{Binding GroundNames}"
                                                  Text="{Binding NewForbiddenGround, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="True"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Time Slot" FontSize="11" Foreground="#555"/>
                                        <ComboBox Width="150" ItemsSource="{Binding TimeSlotDisplays}"
                                                  SelectedItem="{Binding NewForbiddenTimeSlot}"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Division" FontSize="11" Foreground="#555"/>
                                        <ComboBox Width="130" ItemsSource="{Binding FilterDivisions}"
                                                  Text="{Binding NewForbiddenDivision, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="True"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom">
                                        <Button Content="➕ Add"    Command="{Binding AddForbiddenSlotCommand}"    Padding="10,5" Margin="0,0,6,0"/>
                                        <Button Content="🗑 Remove" Command="{Binding RemoveForbiddenSlotCommand}" Padding="10,5" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </WrapPanel>
                                <ListBox Grid.Row="1" ItemsSource="{Binding ForbiddenSlots}"
                                         SelectedItem="{Binding SelectedForbiddenSlot}"
                                         DisplayMemberPath="Display" Height="65"/>
                            </Grid>
                        </Expander>
                    </Border>

                    <!-- Scheduled matches grid -->
                    <DataGrid Grid.Row="2" x:Name="MatchGrid"
                              ItemsSource="{Binding FilteredScheduledMatches}"
                              SelectedItem="{Binding SelectedMatch}"
                              Style="{StaticResource Grid}"
                              SelectionMode="Extended"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"              Binding="{Binding Sequence}"     Width="45"  IsReadOnly="True" SortMemberPath="Sequence"/>
                            <DataGridTextColumn Header="Division"       Binding="{Binding DivisionName}" Width="110" IsReadOnly="True" SortMemberPath="DivisionName"/>
                            <DataGridTextColumn Header="Date"           Binding="{Binding DateDisplay}"  Width="100" IsReadOnly="True" SortMemberPath="DateDisplay"/>
                            <DataGridTextColumn Header="Time"           Binding="{Binding TimeRange}"    Width="135" IsReadOnly="True" SortMemberPath="TimeRange"/>
                            <DataGridTextColumn Header="Team One"       Binding="{Binding TeamOne}"      Width="*"   IsReadOnly="True" SortMemberPath="TeamOne"/>
                            <DataGridTextColumn Header="Team Two"       Binding="{Binding TeamTwo}"      Width="*"   IsReadOnly="True" SortMemberPath="TeamTwo"/>
                            <DataGridTextColumn Header="Ground ✎"       Binding="{Binding GroundName,  UpdateSourceTrigger=LostFocus}" Width="120" SortMemberPath="GroundName"/>
                            <DataGridTextColumn Header="Umpiring ✎"     Binding="{Binding UmpireOne,   UpdateSourceTrigger=LostFocus}" Width="130" SortMemberPath="UmpireOne"/>
                            <DataGridCheckBoxColumn Header="Fixed 🔒"   Binding="{Binding IsFixed, UpdateSourceTrigger=PropertyChanged}" Width="65"/>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasConflict}" Value="True">
                                        <Setter Property="Background" Value="#FFEEEE"/>
                                        <Setter Property="ToolTip"    Value="⚠ Scheduling conflict"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsFixed}" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                        <Setter Property="ToolTip"    Value="🔒 Fixed — won't be moved by Reschedule"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══ TAB 2: UNSCHEDULED ══════════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ Unscheduled"/>
                        <Border Background="#E65100" CornerRadius="8" Padding="5,1" Margin="6,0,0,0">
                            <TextBlock Text="{Binding UnscheduledMatches.Count, Mode=OneWay}"
                                       Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- action bar -->
                        <RowDefinition Height="*"/>     <!-- unscheduled grid -->
                    </Grid.RowDefinitions>

                    <!-- Action bar -->
                    <Border Grid.Row="0" Style="{StaticResource Pill}">
                        <WrapPanel>
                            <Button Content="↔ Move Analyzer"
                                    Padding="14,6" Margin="0,0,8,0"
                                    Command="{Binding OpenRescheduleAnalyzerCommand}"
                                    Background="#1565C0" Foreground="White" FontWeight="SemiBold"
                                    ToolTip="Open Move Analyzer for the selected unscheduled match — explore slots, resolve conflicts, commit"/>
                            <Separator Width="1" Height="22" Background="#CCC" Margin="0,0,8,0"/>
                            <Button Content="✅ Relax All Selected"   Padding="10,5" Margin="0,0,6,0"
                                    Command="{Binding RelaxAllConstraintsCommand}"
                                    CommandParameter="{Binding ElementName=UnscheduledGrid}"/>
                            <Button Content="🚫 Clear Relaxations"    Padding="10,5" Margin="0,0,6,0"
                                    Command="{Binding RelaxNoConstraintsCommand}"
                                    CommandParameter="{Binding ElementName=UnscheduledGrid}"/>
                            <Button Content="🔁 Backtrack Reschedule" Padding="12,5" Margin="0,0,6,0"
                                    Command="{Binding BacktrackRescheduleCommand}"
                                    Background="#E65100" Foreground="White" FontWeight="SemiBold"
                                    ToolTip="Retry placing unscheduled matches using their relaxation flags"/>
                            <Separator Width="1" Height="22" Background="#CCC" Margin="0,0,6,0"/>
                            <Button Content="📤 Export Unscheduled"   Padding="10,5" Margin="0,0,6,0"
                                    Command="{Binding ExportUnscheduledCommand}"/>
                            <Button Content="🗑 Remove Selected"      Padding="10,5"
                                    Command="{Binding RemoveUnscheduledMatchCommand}"/>
                            <TextBlock VerticalAlignment="Center" Margin="14,0,0,0"
                                       FontSize="11" Foreground="#555">
                                <Run FontWeight="SemiBold" Foreground="#E65100"
                                     Text="{Binding UnscheduledMatches.Count, StringFormat='{}⚠ {0} unscheduled', Mode=OneWay}"/>
                                <Run Text=" — select a match and click Move Analyzer to explore slots."/>
                            </TextBlock>
                        </WrapPanel>
                    </Border>

                    <!-- Unscheduled matches grid (constraint relaxation) -->
                    <DataGrid Grid.Row="1" x:Name="UnscheduledGrid"
                              ItemsSource="{Binding UnscheduledMatches}"
                              SelectedItem="{Binding SelectedUnscheduledMatch}"
                              Style="{StaticResource Grid}"
                              SelectionMode="Extended"
                              IsReadOnly="False"
                              Background="#FFFDE7">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Padding" Value="4,4"/>
                                <Setter Property="Background" Value="#FFE0B2"/>
                                <Setter Property="BorderBrush" Value="#FFCC80"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Division" Binding="{Binding Division}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Team One" Binding="{Binding TeamOne}"  Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Team Two" Binding="{Binding TeamTwo}"  Width="*"   IsReadOnly="True"/>
                            <DataGridTextColumn Header="Reason"   Binding="{Binding Reason}"   Width="170" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxGroundFairness,      UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">Ground&#10;Fairness</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxUmpireFairness,      UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">Umpire&#10;Fairness</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxTimeSlotFairness,    UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">Slot&#10;Fairness</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxMaxGapRule,          UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">2 Week&#10;Break</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxOneMatchPerWeekend,  UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">1/&#10;Weekend</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxTimeSlotRestriction, UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">Slot&#10;Restrict</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxDateRestriction,     UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">Date&#10;Restrict</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridCheckBoxColumn Width="72" Binding="{Binding RelaxDiscardedDates,      UpdateSourceTrigger=PropertyChanged}">
                                <DataGridCheckBoxColumn.Header><TextBlock TextAlignment="Center" FontSize="11">Blackout&#10;Dates</TextBlock></DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelaxGroundFairness}" Value="True">
                                        <Setter Property="Background" Value="#FFF9C4"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding RelaxDiscardedDates}" Value="True">
                                        <Setter Property="Background" Value="#FFF9C4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>

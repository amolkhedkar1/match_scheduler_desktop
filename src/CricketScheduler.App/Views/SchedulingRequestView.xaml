<UserControl x:Class="CricketScheduler.App.Views.SchedulingRequestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input form -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="6"
                Padding="14" Background="#FAFAFA">
            <StackPanel>
                <TextBlock Text="Add Team Unavailability Request" Style="{StaticResource SectionHeader}"/>
                <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,10" FontSize="12">
                    Capture dates when a team is unavailable. Leave Start/End Time blank to block the <Bold>entire day</Bold>.
                    Providing a time range blocks only that slot.
                </TextBlock>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Team Name *" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding AllTeamNames}"
                                  Text="{Binding NewRequestTeam, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Padding="4"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Date * (yyyy-MM-dd)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding NewRequestDate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldInput}" ToolTip="e.g. 2026-05-10"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Start Time (HH:mm)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding NewRequestStartTime, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldInput}" ToolTip="Optional e.g. 09:30"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="End Time (HH:mm)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding NewRequestEndTime, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldInput}" ToolTip="Optional e.g. 11:30"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Add Request" Command="{Binding AddRequestCommand}"
                            Padding="12,6" Margin="0,0,8,0"/>
                    <Button Content="Import CSV" Command="{Binding ImportRequestsCommand}"
                            Padding="10,6" Margin="0,0,8,0"/>
                    <Button Content="Save Requests" Command="{Binding SaveRequestsCommand}"
                            FontWeight="SemiBold" Padding="12,6" Background="#4CAF50" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Requests DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding SchedulingRequests}"
                  SelectedItem="{Binding SelectedRequest}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Team"       Binding="{Binding TeamName}"       Width="180"/>
                <DataGridTextColumn Header="Date"       Binding="{Binding Date}"            Width="120"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTimeDisplay}" Width="120"/>
                <DataGridTextColumn Header="End Time"   Binding="{Binding EndTimeDisplay}"   Width="120"/>
                <DataGridTextColumn Header="Block Type" Binding="{Binding BlockType}"        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="3" Content="Remove Selected Request" Command="{Binding RemoveRequestCommand}"
                HorizontalAlignment="Left" Padding="10,5" Margin="0,8,0,0"/>
    </Grid>
</UserControl>

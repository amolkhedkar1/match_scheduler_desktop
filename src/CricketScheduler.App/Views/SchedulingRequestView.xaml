<UserControl x:Class="CricketScheduler.App.Views.SchedulingRequestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <UserControl.Resources>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><!-- form -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/><!-- multi-slot panel -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/><!-- toolbar: search + export + delete -->
            <RowDefinition Height="*"/>  <!-- grid -->
        </Grid.RowDefinitions>

        <!-- ══ INPUT FORM ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5"
                Padding="14,12" Background="#FAFAFA">
            <StackPanel>
                <TextBlock Text="Add Team Unavailability Request" Style="{StaticResource Hdr}"/>
                <TextBlock FontSize="12" Foreground="#555" TextWrapping="Wrap" Margin="0,0,0,10">
                    Record when a team cannot play. Leave <Bold>Time Slot</Bold> blank to block the full day.
                    Or select <Bold>multiple slots</Bold> below and use "Block Selected Slots" to combine them into one range.
                </TextBlock>

                <!-- Single request: Team | Date | Single Slot -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Team *" Style="{StaticResource FL}"/>
                        <ComboBox ItemsSource="{Binding AllTeamNames}"
                                  Text="{Binding NewRequestTeam, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Padding="4,5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Date *" Style="{StaticResource FL}"/>
                        <DatePicker SelectedDate="{Binding NewRequestDate}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Time Slot (blank = full day)" Style="{StaticResource FL}"/>
                        <ComboBox ItemsSource="{Binding TimeSlotDisplays}"
                                  SelectedItem="{Binding NewRequestTimeSlot}" Padding="4,5"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6" VerticalAlignment="Bottom">
                        <Button Content="➕ Add" Command="{Binding AddRequestCommand}"
                                Padding="12,6"/>
                    </StackPanel>
                </Grid>

                <!-- Multi-slot combined block -->
                <Expander Header="Block multiple time slots at once (combined range)" Margin="0,10,0,0">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock FontSize="11" Foreground="#666" Margin="0,0,0,6">
                            Select multiple slots below (Ctrl+click), then click "Block Selected Slots" to add a single request spanning the combined time range.
                        </TextBlock>
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="⏱ Block Selected Slots" Padding="12,5" Margin="8,0,0,0"
                                    Command="{Binding AddCombinedSlotConstraintCommand}"
                                    CommandParameter="{Binding ElementName=SlotListBox}"/>
                            <ListBox x:Name="SlotListBox" ItemsSource="{Binding TimeSlotDisplays}"
                                     SelectionMode="Extended" Height="80"/>
                        </DockPanel>
                    </StackPanel>
                </Expander>

                <!-- Import / Save row -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="📂 Import CSV" Command="{Binding ImportRequestsCommand}"
                            Padding="10,6" Margin="0,0,8,0"/>
                    <Button Content="💾 Save All" Command="{Binding SaveRequestsCommand}"
                            FontWeight="SemiBold" Padding="12,6"
                            Background="#4CAF50" Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ SEARCH + EXPORT TOOLBAR ══════════════════════════════════════ -->
        <DockPanel Grid.Row="4" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox DockPanel.Dock="Left" Width="220" Padding="4,3" Margin="0,0,10,0"
                     Text="{Binding RequestSearchText, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter by team name or date"/>
            <Button DockPanel.Dock="Left" Content="📤 Export Filtered"
                    Command="{Binding ExportFilteredRequestsCommand}"
                    Padding="10,5" Margin="0,0,6,0"/>
            <Button DockPanel.Dock="Left" Content="🗑 Delete Selected"
                    Command="{Binding DeleteSelectedRequestsCommand}"
                    CommandParameter="{Binding ElementName=RequestGrid}"
                    Padding="10,5"/>
        </DockPanel>

        <!-- ══ REQUESTS GRID ════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="5"
                  x:Name="RequestGrid"
                  ItemsSource="{Binding FilteredRequests}"
                  SelectedItem="{Binding SelectedRequest}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  CanUserResizeColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Team"       Binding="{Binding TeamName}"        Width="200"/>
                <DataGridTextColumn Header="Date"       Binding="{Binding Date}"             Width="120"/>
                <DataGridTextColumn Header="Start Time" Binding="{Binding StartTimeDisplay}" Width="120"/>
                <DataGridTextColumn Header="End Time"   Binding="{Binding EndTimeDisplay}"   Width="120"/>
                <DataGridTextColumn Header="Block Type" Binding="{Binding BlockType}"        Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

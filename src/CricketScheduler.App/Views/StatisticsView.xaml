<UserControl x:Class="CricketScheduler.App.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="TotalHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
        <Style x:Key="TeamHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="10">

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#F5F5F5" BorderBrush="#CCC"
                BorderThickness="1" CornerRadius="4" Padding="10,6" Margin="0,0,0,8">
            <DockPanel>
                <Button x:Name="ExportAllStatsExcelBtn" DockPanel.Dock="Right"
                        Content="📊 Export All Stats (Excel)"
                        Padding="10,3" FontSize="12"/>
                <TextBlock Text="Schedule Statistics" FontSize="14" FontWeight="SemiBold"
                           Foreground="#333" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TabControl>

            <!-- Tab 1: Matches Scheduled -->
            <TabItem Header="Matches Scheduled">
                <DockPanel Margin="4">
                    <DockPanel DockPanel.Dock="Top" Margin="0,6,0,6">
                        <Button x:Name="ExportAllMatchesBtn" DockPanel.Dock="Right"
                                Content="📤 Export All" Padding="10,4" Margin="6,0,0,0"/>
                        <TextBlock Foreground="#555" FontSize="11" VerticalAlignment="Center"
                                   Text="1 = match scheduled · = none | Last row = matches per date | Last column = per team"/>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="MatchesPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Tab 2: Umpiring Schedule -->
            <TabItem Header="Umpiring Schedule">
                <DockPanel Margin="4">
                    <DockPanel DockPanel.Dock="Top" Margin="0,6,0,6">
                        <Button x:Name="ExportAllUmpiringBtn" DockPanel.Dock="Right"
                                Content="📤 Export All" Padding="10,4" Margin="6,0,0,0"/>
                        <TextBlock Foreground="#555" FontSize="11" VerticalAlignment="Center"
                                   Text="1 = umpiring duty that date · = none | Last row = teams umpiring per date | Last column = dates per team"/>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="UmpiringPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Tab 3: Ground Assignment -->
            <TabItem Header="Ground Assignment">
                <DockPanel Margin="4">
                    <DockPanel DockPanel.Dock="Top" Margin="0,6,0,6">
                        <Button x:Name="ExportAllGroundBtn" DockPanel.Dock="Right"
                                Content="📤 Export All" Padding="10,4" Margin="6,0,0,0"/>
                        <TextBlock Foreground="#555" FontSize="11" VerticalAlignment="Center"
                                   Text="Matches played at each ground | Last row = total per ground | Last column = total per team"/>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="GroundPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- Tab 4: Matches Per Week Per Ground -->
            <TabItem Header="Weekly Ground Usage">
                <DockPanel Margin="4">
                    <DockPanel DockPanel.Dock="Top" Margin="0,6,0,6">
                        <Button x:Name="ExportAllWeeklyGroundBtn" DockPanel.Dock="Right"
                                Content="📤 Export All" Padding="10,4" Margin="6,0,0,0"/>
                        <TextBlock Foreground="#555" FontSize="11" VerticalAlignment="Center"
                                   Text="Total matches per week (Mon–Sun) per ground | Last row = total per week | Last column = total per ground"/>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="WeeklyGroundPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>

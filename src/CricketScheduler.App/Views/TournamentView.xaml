<UserControl x:Class="CricketScheduler.App.Views.TournamentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Hdr" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FL" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,8,0,2"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT: Tournament info + blackout dates ════════════════════ -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Tournament Details" Style="{StaticResource Hdr}"/>

                <TextBlock Text="Tournament Name" Style="{StaticResource FL}"/>
                <TextBox Text="{Binding TournamentName, UpdateSourceTrigger=PropertyChanged}"
                         Padding="5" MaxLength="120"/>

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Start Date" Style="{StaticResource FL}" Margin="0,0,0,2"/>
                        <DatePicker SelectedDate="{Binding TournamentStartDate}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="End Date" Style="{StaticResource FL}" Margin="0,0,0,2"/>
                        <DatePicker SelectedDate="{Binding TournamentEndDate}"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,14"/>

                <!-- Blackout dates -->
                <TextBlock Text="Blackout / Discarded Dates" Style="{StaticResource Hdr}"/>
                <TextBlock Text="Matches will not be scheduled on these dates."
                           Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                <DockPanel LastChildFill="True" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="➕ Add"
                            Command="{Binding AddDiscardedDateCommand}" Padding="10,5" Margin="8,0,0,0"/>
                    <DatePicker SelectedDate="{Binding NewDiscardedDate}"/>
                </DockPanel>
                <ListBox ItemsSource="{Binding DiscardedDates}" Height="130"
                         SelectedItem="{Binding SelectedDiscardedDate}"
                         SelectionMode="Extended" x:Name="DateList"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <Button Content="🗑 Remove Selected" Command="{Binding RemoveDiscardedDateCommand}"
                            Padding="8,4" Margin="0,0,6,0"/>
                </StackPanel>

                <Separator Margin="0,14"/>
                <Button Content="💾 Save Tournament" Command="{Binding SaveTournamentCommand}"
                        FontWeight="SemiBold" Padding="14,8" HorizontalAlignment="Left"
                        Background="#4CAF50" Foreground="White"/>
            </StackPanel>

            <!-- ══ RIGHT: Grounds + Time Slots ═══════════════════════════════ -->
            <StackPanel Grid.Column="2">

                <!-- Grounds -->
                <TextBlock Text="Grounds" Style="{StaticResource Hdr}"/>
                <TextBlock Text="Playing venues available for this tournament."
                           Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                <DockPanel LastChildFill="True" Margin="0,0,0,6">
                    <Button DockPanel.Dock="Right" Content="➕ Add"
                            Command="{Binding AddGroundCommand}" Padding="10,5" Margin="8,0,0,0"/>
                    <TextBox Text="{Binding NewGroundName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5" ToolTip="e.g. OCG, Central Park"/>
                </DockPanel>
                <ListBox ItemsSource="{Binding GroundNames}" Height="120"
                         SelectedItem="{Binding SelectedGroundName}" SelectionMode="Extended"/>
                <Button Content="🗑 Remove Selected" Command="{Binding RemoveGroundCommand}"
                        HorizontalAlignment="Left" Padding="8,4" Margin="0,4,0,0"/>

                <Separator Margin="0,14"/>

                <!-- Time Slots -->
                <TextBlock Text="Match Time Slots" Style="{StaticResource Hdr}"/>
                <TextBlock Text="Define available start–end windows for matches."
                           Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition Width="10"/>
                        <ColumnDefinition/><ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Start (HH:mm)" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NewSlotStart, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="5" ToolTip="e.g. 07:00"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="End (HH:mm)" FontSize="11" Foreground="#555" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding NewSlotEnd, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="5" ToolTip="e.g. 09:00"/>
                    </StackPanel>
                    <Button Grid.Column="4" Content="➕ Add Slot"
                            Command="{Binding AddTimeSlotCommand}"
                            Padding="10,5" VerticalAlignment="Bottom"/>
                </Grid>
                <ListBox ItemsSource="{Binding TimeSlotDisplays}" Height="120"
                         SelectedItem="{Binding SelectedTimeSlotDisplay}" SelectionMode="Extended"/>
                <Button Content="🗑 Remove Selected Slot" Command="{Binding RemoveTimeSlotCommand}"
                        HorizontalAlignment="Left" Padding="8,4" Margin="0,4,0,0"/>

                <Separator Margin="0,14"/>

                <!-- Upload additional CSV -->
                <TextBlock Text="Upload Additional Data (CSV)" Style="{StaticResource Hdr}"/>
                <TextBlock Text="Append teams/divisions from an additional CSV file."
                           Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                <Button Content="📂 Append Divisions CSV" Command="{Binding ImportDivisionsCommand}"
                        HorizontalAlignment="Left" Padding="10,5"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
